---
---
<section id="about" class="about-section">
  <div class="container">
    <h2 class="section-title">Sobre Mí</h2>
    
    <div class="about-grid">
      <!-- Profile Card -->
      <div class="about-profile glass-card">
        <div class="terminal-header">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
          <span class="terminal-title">kevin_frias.sh</span>
        </div>
        <div class="terminal-body">
          <p class="cmd"><span class="prompt">$</span> cat about_me.md</p>
          <div class="profile-content">
            <p class="lead">
              Como Administrador de Sistemas Mid-Level, combino la administración de sistemas tradicionales con automatización de infraestructura moderna.
            </p>
            <p>
              Tengo amplia experiencia trabajando en <strong>modelos de trabajo híbrido</strong>, lo que me ha permitido consolidar una fuerte disciplina, comunicación efectiva asíncrona y habilidades de autogestión para liderar proyectos tecnológicos desde cualquier lugar.
            </p>
            <p>
              Mi enfoque profesional está en la <strong>infraestructura como código (IaC)</strong>, securización de accesos e identidades, automatización de tareas repetitivas mediante scripting, y el diseño de tuberías de integración y despliegue continuo (CI/CD) seguras.
            </p>
          </div>
          
          <p class="cmd"><span class="prompt">$</span> credentials --list</p>
          <div class="skills-mini">
            <span class="skill-tag">Systems Admin</span>
            <span class="skill-tag">DevSecOps</span>
            <span class="skill-tag">Microsoft Entra ID</span>
            <span class="skill-tag">Intune</span>
            <span class="skill-tag">Redes</span>
            <span class="skill-tag">Híbrido</span>
          </div>
        </div>
      </div>

      <!-- Human / Off-duty Card -->
      <div class="about-human glass-card">
        <h3 class="card-title">Fuera del Teclado</h3>
        <p class="card-subtitle">Mis pasiones, pasatiempos y actividades fuera de la oficina.</p>
        
        <div class="human-interests">
          <!-- Chess interest -->
          <div class="interest-item chess-box">
            <div class="interest-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2a3 3 0 0 0-3 3v2.2L6.3 8.7A1.5 1.5 0 0 0 6 9.8V17a3 3 0 0 0 3 3h6a3 3 0 0 0 3-3V9.8a1.5 1.5 0 0 0-.3-1.1L15 7.2V5a3 3 0 0 0-3-3z"/>
                <path d="M9 13.5h6"/>
                <path d="M8 17h8"/>
              </svg>
            </div>
            <div class="interest-info">
              <h4>Ajedrez</h4>
              <p>Me gusta practicar ajedrez de forma recreativa, desafiando mi razonamiento táctico y capacidad de anticipación.</p>
            </div>
          </div>

          <!-- Rubik's Cubes -->
          <div class="interest-item rubik-box">
            <div class="interest-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                <line x1="12" y1="22.08" x2="12" y2="12"/>
              </svg>
            </div>
            <div class="interest-info">
              <h4>Cubos de Rubik</h4>
              <p>Me gusta armar cubos de Rubik de distintos tamaños, entrenando la memoria muscular y el reconocimiento de patrones.</p>
            </div>
          </div>

          <!-- Reading -->
          <div class="interest-item reading-box">
            <div class="interest-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
              </svg>
            </div>
            <div class="interest-info">
              <h4>Lectura</h4>
              <p>Me gusta leer con regularidad sobre tecnología, desarrollo profesional y divulgación para seguir expandiendo mis horizontes.</p>
            </div>
          </div>

          <!-- Piano interest (Interactive!) -->
          <div class="interest-item piano-box">
            <div class="interest-info-full">
              <div class="piano-title-row">
                <svg class="piano-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <line x1="9" y1="3" x2="9" y2="21"/>
                  <line x1="15" y1="3" x2="15" y2="21"/>
                </svg>
                <h4>Piano</h4>
              </div>
              <p class="piano-desc">Practico piano de manera habitual, explorando nuevas piezas y melodías. ¡Pasa el mouse sobre el teclado para tocar!</p>
              
              <!-- Interactive Keyboard -->
              <div class="piano-keyboard">
                <div class="key white" data-note="261.63"><span>Do</span></div>
                <div class="key black" data-note="277.18"></div>
                <div class="key white" data-note="293.66"><span>Re</span></div>
                <div class="key black" data-note="311.13"></div>
                <div class="key white" data-note="329.63"><span>Mi</span></div>
                <div class="key white" data-note="349.23"><span>Fa</span></div>
                <div class="key black" data-note="369.99"></div>
                <div class="key white" data-note="392.00"><span>Sol</span></div>
                <div class="key black" data-note="415.30"></div>
                <div class="key white" data-note="440.00"><span>La</span></div>
                <div class="key black" data-note="466.16"></div>
                <div class="key white" data-note="493.88"><span>Si</span></div>
                <div class="key white" data-note="523.25"><span>Do</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: 100px 0;
    position: relative;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: stretch;
  }

  /* Terminal Card Design */
  .about-profile {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .terminal-header {
    background: rgba(15, 23, 42, 0.6);
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot.red { background-color: #EF4444; }
  .dot.yellow { background-color: #F59E0B; }
  .dot.green { background-color: #10B981; }

  .terminal-title {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-left: 0.5rem;
  }

  .terminal-body {
    padding: 1.5rem;
    font-family: var(--font-body);
  }

  .cmd {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .cmd .prompt {
    color: var(--text-muted);
    margin-right: 0.5rem;
  }

  .profile-content {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .profile-content strong {
    color: var(--text-primary);
  }

  .lead {
    font-size: 1.1rem;
    color: var(--text-primary);
    font-weight: 500;
  }

  .skills-mini {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .skill-tag {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    background: rgba(0, 255, 136, 0.05);
    border: 1px solid rgba(0, 255, 136, 0.15);
    color: var(--accent);
  }

  /* Human Section Card */
  .about-human {
    padding: 2rem;
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-family: var(--font-title);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .card-subtitle {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .human-interests {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .interest-item {
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.03);
    transition: var(--transition-smooth);
  }

  .interest-item:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.06);
    transform: translateX(4px);
  }

  .interest-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 8px;
    background: rgba(0, 255, 136, 0.06);
    color: var(--accent);
    flex-shrink: 0;
  }

  .interest-info {
    flex-grow: 1;
  }

  .interest-info h4 {
    font-family: var(--font-title);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .interest-info p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .elo-progress-container {
    margin-top: 0.75rem;
    position: relative;
  }

  .elo-bar {
    height: 6px;
    border-radius: 3px;
    background: linear-gradient(to right, var(--accent), #00D2FF);
    box-shadow: 0 0 8px rgba(0, 255, 136, 0.4);
  }

  .elo-progress-container::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 6px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    z-index: -1;
  }

  .elo-label {
    display: block;
    margin-top: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* Piano Box specific styling */
  .piano-box {
    flex-direction: column;
    gap: 1rem;
  }

  .piano-title-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--accent);
  }

  .piano-title-row h4 {
    font-family: var(--font-title);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .piano-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .piano-keyboard {
    position: relative;
    display: flex;
    width: 100%;
    height: 90px;
    background-color: #000;
    border-radius: 6px;
    overflow: hidden;
    padding-bottom: 2px;
    user-select: none;
  }

  .key {
    cursor: pointer;
    transition: background-color 0.1s ease, transform 0.1s ease, box-shadow 0.1s ease;
  }

  .key.white {
    flex-grow: 1;
    background-color: #ECEFF1;
    border-right: 1px solid #B0BEC5;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 6px;
  }

  .key.white span {
    font-size: 0.65rem;
    color: #455A64;
    font-weight: 600;
    pointer-events: none;
  }

  .key.white:last-child {
    border-right: none;
  }

  .key.white:hover, .key.white.active {
    background-color: #FFFFFF;
    box-shadow: inset 0 -8px 0 var(--accent);
  }

  .key.black {
    width: 6.5%;
    height: 55px;
    background-color: #212121;
    border-bottom: 2px solid #000;
    position: absolute;
    z-index: 2;
    transform-origin: top;
  }

  /* Absolute positions of black keys */
  .key.black:nth-of-type(1) { left: 8.5%; }
  .key.black:nth-of-type(2) { left: 20.5%; }
  .key.black:nth-of-type(3) { left: 44.5%; }
  .key.black:nth-of-type(4) { left: 56.5%; }
  .key.black:nth-of-type(5) { left: 68.5%; }
  .key.black:nth-of-type(6) { left: 88.5%; }

  .key.black:hover, .key.black.active {
    background-color: #424242;
    border-bottom-color: var(--accent);
    box-shadow: 0 0 10px rgba(0, 255, 136, 0.4);
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 480px) {
    .piano-keyboard {
      height: 80px;
    }
    
    .key.white span {
      display: none;
    }
  }
</style>

<script>
  // Web Audio API Synth for Interactive Piano
  let audioCtx: AudioContext | null = null;

  function initAudio() {
    if (!audioCtx) {
      audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
    }
    if (audioCtx.state === 'suspended') {
      audioCtx.resume();
    }
  }

  function playTone(frequency: number) {
    try {
      initAudio();
      if (!audioCtx) return;

      const osc = audioCtx.createOscillator();
      const gainNode = audioCtx.createGain();

      osc.type = 'sine'; // Smooth tone
      osc.frequency.setValueAtTime(frequency, audioCtx.currentTime);
      
      gainNode.gain.setValueAtTime(0.12, audioCtx.currentTime); // Low volume
      gainNode.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 1.2); // Decay
      
      osc.connect(gainNode);
      gainNode.connect(audioCtx.destination);
      
      osc.start();
      osc.stop(audioCtx.currentTime + 1.2);
    } catch (e) {
      console.warn("AudioContext failed to load or play:", e);
    }
  }

  const keys = document.querySelectorAll('.key');
  
  keys.forEach(key => {
    // Play tone on mouseenter (hover) or click/touchstart
    const handlePlay = () => {
      const freqAttr = key.getAttribute('data-note');
      if (freqAttr) {
        const freq = parseFloat(freqAttr);
        playTone(freq);
        key.classList.add('active');
        setTimeout(() => key.classList.remove('active'), 150);
      }
    };

    key.addEventListener('mouseenter', (e) => {
      // Only play if mouse button is not pressed or standard hover
      handlePlay();
    });
    
    key.addEventListener('click', handlePlay);
    
    key.addEventListener('touchstart', (e) => {
      e.preventDefault();
      handlePlay();
    });
  });
</script>
