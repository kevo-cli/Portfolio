---
---
<section id="certifications" class="cert-section">
  <div class="container">
    <h2 class="section-title">Certificaciones y Logros</h2>
    
    <div class="cert-grid">
      <!-- Vault (Obtained) -->
      <div class="cert-card glass-card obtained">
        <div class="cert-status">
          <span class="status-badge status-obtained">
            <span class="pulse-dot green"></span>
            Obtenida
          </span>
        </div>
        <div class="cert-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            <circle cx="12" cy="16" r="1"/>
          </svg>
        </div>
        <h3 class="cert-name">HashiCorp Certified: Vault Associate</h3>
        <p class="cert-issuer">HashiCorp</p>
        <p class="cert-desc">Valida la comprensión de la gestión de secretos en la nube, el cifrado de datos en tránsito/reposo y las políticas avanzadas de control de acceso.</p>
        <div class="cert-footer">
          <span class="cert-badge-tag">Seguridad de Secretos</span>
          <span class="cert-badge-tag">DevSecOps</span>
        </div>
      </div>

      <!-- CompTIA Security+ (In progress) -->
      <div class="cert-card glass-card in-progress">
        <div class="cert-status">
          <span class="status-badge status-pending">
            <span class="pulse-dot blue"></span>
            En Progreso
          </span>
        </div>
        <div class="cert-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <h3 class="cert-name">CompTIA Security+</h3>
        <p class="cert-issuer">CompTIA</p>
        <p class="cert-desc">Preparación avanzada para la certificación líder en ciberseguridad, cubriendo criptografía, redes seguras, gestión de amenazas y respuesta a incidentes.</p>
        <div class="cert-footer">
          <span class="cert-badge-tag">Ciberseguridad</span>
          <span class="cert-badge-tag">Redes</span>
        </div>
      </div>

      <!-- ISC2 (In progress) -->
      <div class="cert-card glass-card in-progress">
        <div class="cert-status">
          <span class="status-badge status-pending">
            <span class="pulse-dot blue"></span>
            En Progreso
          </span>
        </div>
        <div class="cert-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16.5 9.4 7.55 4.24a1.79 1.79 0 0 0-2.5 1.53v12.46a1.79 1.79 0 0 0 2.5 1.53L16.5 14.6a1.79 1.79 0 0 0 0-3.2z"/>
          </div>
        <h3 class="cert-name">Certified in Cybersecurity (CC)</h3>
        <p class="cert-issuer">ISC2</p>
        <p class="cert-desc">Desarrollo de competencias fundamentales en los principios de seguridad, controles de acceso, seguridad en redes e ingeniería de seguridad en la nube.</p>
        <div class="cert-footer">
          <span class="cert-badge-tag">Acceso e Identidad</span>
          <span class="cert-badge-tag">Nube</span>
        </div>
      </div>

      <!-- GitHub Foundations (In progress) -->
      <div class="cert-card glass-card in-progress">
        <div class="cert-status">
          <span class="status-badge status-pending">
            <span class="pulse-dot blue"></span>
            En Progreso
          </span>
        </div>
        <div class="cert-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
        </div>
        <h3 class="cert-name">GitHub Foundations</h3>
        <p class="cert-issuer">GitHub</p>
        <p class="cert-desc">Estudio integral del control de versiones con Git, automatización mediante GitHub Actions, gestión de proyectos colaborativos y buenas prácticas.</p>
        <div class="cert-footer">
          <span class="cert-badge-tag">Git / GitHub</span>
          <span class="cert-badge-tag">CI/CD</span>
        </div>
      </div>

      <!-- HackTheBox / HackerOne -->
      <div class="cert-card glass-card lab-participation">
        <div class="cert-status">
          <span class="status-badge status-active">
            <span class="pulse-dot green"></span>
            Participación Activa
          </span>
        </div>
        <div class="cert-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
        </div>
        <h3 class="cert-name">Laboratorios de Seguridad</h3>
        <p class="cert-issuer">HackTheBox & HackerOne</p>
        <p class="cert-desc">Entrenamiento práctico continuo resolviendo desafíos técnicos en laboratorios de penetración simulados, configuraciones seguras e investigación de fallos.</p>
        <div class="cert-footer">
          <span class="cert-badge-tag">HTB Labs</span>
          <span class="cert-badge-tag">Hacking Ético</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cert-section {
    padding: 100px 0;
    position: relative;
  }

  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  .cert-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  /* Specific styling for obtained credentials */
  .cert-card.obtained {
    border-color: rgba(0, 255, 136, 0.15);
    box-shadow: 0 4px 20px rgba(0, 255, 136, 0.03);
  }

  .cert-card.obtained:hover {
    border-color: rgba(0, 255, 136, 0.4);
    box-shadow: 0 8px 30px rgba(0, 255, 136, 0.1);
  }

  .cert-status {
    margin-bottom: 1.5rem;
    display: flex;
    justify-content: flex-start;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.35rem 0.75rem;
    border-radius: 50px;
    text-transform: uppercase;
  }

  .status-obtained {
    background: rgba(0, 255, 136, 0.08);
    color: var(--accent);
    border: 1px solid rgba(0, 255, 136, 0.2);
  }

  .status-pending {
    background: rgba(0, 210, 255, 0.08);
    color: #00D2FF;
    border: 1px solid rgba(0, 210, 255, 0.2);
  }

  .status-active {
    background: rgba(16, 185, 129, 0.08);
    color: #10B981;
    border: 1px solid rgba(16, 185, 129, 0.2);
  }

  .pulse-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    position: relative;
  }

  .pulse-dot.green { background-color: var(--accent); animation: pulseGreen 2s infinite; }
  .pulse-dot.blue { background-color: #00D2FF; animation: pulseBlue 2s infinite; }

  @keyframes pulseGreen {
    0% { box-shadow: 0 0 0 0 rgba(0, 255, 136, 0.7); }
    70% { box-shadow: 0 0 0 6px rgba(0, 255, 136, 0); }
    100% { box-shadow: 0 0 0 0 rgba(0, 255, 136, 0); }
  }

  @keyframes pulseBlue {
    0% { box-shadow: 0 0 0 0 rgba(0, 210, 255, 0.7); }
    70% { box-shadow: 0 0 0 6px rgba(0, 210, 255, 0); }
    100% { box-shadow: 0 0 0 0 rgba(0, 210, 255, 0); }
  }

  .cert-icon {
    color: var(--accent);
    margin-bottom: 1rem;
    opacity: 0.85;
  }

  .cert-card.in-progress .cert-icon {
    color: #00D2FF;
  }

  .cert-name {
    font-family: var(--font-title);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
    line-height: 1.3;
    color: var(--text-primary);
  }

  .cert-issuer {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .cert-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .cert-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    border-top: 1px solid var(--border-color);
    padding-top: 1rem;
  }

  .cert-badge-tag {
    font-size: 0.75rem;
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.03);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
</style>
