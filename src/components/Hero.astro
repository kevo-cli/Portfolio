---
<section id="home" class="hero-section">
  <div class="container hero-container">
    <div class="hero-grid">
      <!-- Left Info (Top/Left in Bruno Simon layout) -->
      <div class="hero-top-left animate-fade-in">
        <h1 class="main-title">
          KEVIN FRIAS<span class="title-dot">.</span>
        </h1>
        <div class="typewriter-container">
          <span class="typewriter-prefix">Especialista en</span>
          <span id="typewriter" class="typewriter-text"></span>
          <span class="cursor">|</span>
        </div>
      </div>

      <!-- Center Avatar -->
      <div class="hero-center animate-scale-in">
        <div class="avatar-glow-wrapper">
          <div class="avatar-ring"></div>
          <img src="/avatar.svg" alt="Kevin Frias Avatar" class="hero-avatar" />
        </div>
      </div>

      <!-- Right Description -->
      <div class="hero-bottom-right animate-fade-in-delayed">
        <p class="bio-text">
          Diseño e implemento infraestructura sólida y automatizada. Me enfoco en la seguridad, eficiencia y escalabilidad de los entornos de TI, facilitando la transición hacia prácticas DevSecOps.
        </p>
        <div class="hero-actions">
          <a href="#projects" class="btn btn-primary">Ver Proyectos</a>
          <a href="#experience" class="btn btn-secondary">Mi Trayectoria</a>
        </div>
      </div>
    </div>

    <!-- Footer of the Hero (Socials, Contact, Scroll) -->
    <div class="hero-footer animate-fade-in-delayed">
      <div class="contact-quick">
        <div><span class="footer-label">E:</span> <a href="mailto:kevinrijo011@gmail.com" class="footer-link">kevinrijo011@gmail.com</a></div>
        <div><span class="footer-label">W:</span> <span class="footer-val">Trabajo Híbrido / Remoto</span></div>
      </div>
      
      <div class="social-links">
        <a href="https://github.com/kevo-cli" target="_blank" rel="noopener noreferrer" class="social-link">/ GitHub</a>
        <a href="https://www.linkedin.com/in/kevinrijo/" target="_blank" rel="noopener noreferrer" class="social-link">/ LinkedIn</a>
        <a href="https://hackthebox.com" target="_blank" rel="noopener noreferrer" class="social-link">/ HackTheBox</a>
        <a href="mailto:kevinrijo011@gmail.com" class="social-link">/ Email</a>
      </div>
    </div>

    <div class="scroll-indicator">
      <span class="scroll-text">SCROLL</span>
      <span class="scroll-line"></span>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 100px;
    padding-bottom: 60px;
    overflow: hidden;
  }

  .hero-container {
    width: 100%;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: calc(100vh - 160px);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr;
    align-items: center;
    gap: 2rem;
    margin-top: auto;
    margin-bottom: auto;
    width: 100%;
  }

  .hero-top-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .greeting {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--accent);
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .main-title {
    font-family: var(--font-title);
    font-size: 4.5rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    position: relative;
  }

  .title-dot {
    color: var(--accent);
    text-shadow: 0 0 15px rgba(0, 255, 136, 0.6);
  }

  .typewriter-container {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .typewriter-text {
    color: var(--text-primary);
    font-weight: 700;
    border-bottom: 2px solid var(--accent);
    padding-bottom: 2px;
  }

  .cursor {
    color: var(--accent);
    animation: blink 0.8s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Center Avatar Styles */
  .hero-center {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .avatar-glow-wrapper {
    position: relative;
    width: 280px;
    height: 280px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-avatar {
    width: 90%;
    height: 90%;
    object-fit: contain;
    z-index: 2;
    transition: var(--transition-smooth);
    filter: drop-shadow(0 0 20px rgba(0, 255, 136, 0.15));
  }

  .avatar-ring {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 1px dashed rgba(0, 255, 136, 0.2);
    animation: rotate 40s linear infinite;
    z-index: 1;
  }

  .avatar-ring::before {
    content: '';
    position: absolute;
    top: 5%;
    left: 5%;
    width: 90%;
    height: 90%;
    border-radius: 50%;
    border: 1.5px solid rgba(0, 255, 136, 0.05);
  }

  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .avatar-glow-wrapper:hover .hero-avatar {
    transform: scale(1.05) translateY(-5px);
    filter: drop-shadow(0 0 30px rgba(0, 255, 136, 0.35));
  }

  /* Right Side Bio & Actions */
  .hero-bottom-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .bio-text {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
  }

  .btn {
    display: inline-block;
    padding: 0.8rem 1.75rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    text-align: center;
    transition: var(--transition-smooth);
  }

  .btn-primary {
    background-color: var(--accent);
    color: #080B11;
    box-shadow: 0 4px 15px rgba(0, 255, 136, 0.25);
  }

  .btn-primary:hover {
    background-color: var(--accent-hover);
    box-shadow: 0 6px 20px rgba(0, 255, 136, 0.4);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border-color);
  }

  .btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.05);
    border-color: var(--text-secondary);
    transform: translateY(-2px);
  }

  /* Hero Footer (Contact & Socials) */
  .hero-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border-color);
    padding-top: 2rem;
    margin-top: 3rem;
    width: 100%;
  }

  .contact-quick {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .footer-label {
    color: var(--text-muted);
    font-family: var(--font-mono);
    margin-right: 0.5rem;
  }

  .footer-link:hover {
    color: var(--accent);
  }

  .footer-val {
    color: var(--text-primary);
    font-weight: 500;
  }

  .social-links {
    display: flex;
    gap: 1.5rem;
  }

  .social-link {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .social-link:hover {
    color: var(--accent);
    transform: translateX(3px);
  }

  /* Vertical Scroll Indicator on right side */
  .scroll-indicator {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    pointer-events: none;
  }

  .scroll-text {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.2em;
    writing-mode: vertical-rl;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    position: relative;
    overflow: hidden;
  }

  .scroll-line::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 15px;
    background-color: var(--text-primary);
    animation: scroll-anim 2s infinite ease-in-out;
  }

  @keyframes scroll-anim {
    0% { transform: translateY(-100%); }
    80%, 100% { transform: translateY(60px); }
  }

  /* Micro-animations */
  .animate-fade-in {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeIn 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .animate-scale-in {
    opacity: 0;
    transform: scale(0.9);
    animation: fadeIn 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    animation-delay: 0.2s;
  }

  .animate-fade-in-delayed {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeIn 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    animation-delay: 0.4s;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr 1fr;
    }
    
    .hero-bottom-right {
      grid-column: span 2;
      flex-direction: row;
      align-items: center;
      gap: 3rem;
      margin-top: 2rem;
    }

    .bio-text {
      flex: 1.5;
    }

    .hero-actions {
      flex: 1;
      flex-direction: column;
    }

    .avatar-glow-wrapper {
      width: 240px;
      height: 240px;
    }
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }

    .hero-top-left {
      align-items: center;
    }

    .main-title {
      font-size: 3.5rem;
    }

    .hero-center {
      grid-row: 1;
    }

    .hero-bottom-right {
      grid-column: span 1;
      flex-direction: column;
      gap: 1.5rem;
      text-align: center;
      margin-top: 0;
    }

    .hero-actions {
      width: 100%;
      flex-direction: row;
      justify-content: center;
    }

    .btn {
      flex: 1;
      max-width: 200px;
    }

    .hero-footer {
      flex-direction: column;
      gap: 1.5rem;
      text-align: center;
    }

    .social-links {
      flex-wrap: wrap;
      justify-content: center;
    }

    .scroll-indicator {
      display: none;
    }
  }
</style>

<script>
  // Simple High-Performance Typewriter Effect
  const words = ["Automatización", "DevSecOps", "Microsoft Entra ID", "Microsoft Intune", "Infraestructura como Código", "Seguridad & Redes"];
  let wordIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  const typewriterElement = document.getElementById('typewriter');
  
  function type() {
    if (!typewriterElement) return;
    
    const currentWord = words[wordIndex];
    
    if (isDeleting) {
      // Remove characters
      typewriterElement.textContent = currentWord.substring(0, charIndex - 1);
      charIndex--;
    } else {
      // Add characters
      typewriterElement.textContent = currentWord.substring(0, charIndex + 1);
      charIndex++;
    }
    
    let typeSpeed = isDeleting ? 40 : 80;
    
    if (!isDeleting && charIndex === currentWord.length) {
      // Pause at full word
      typeSpeed = 1800;
      isDeleting = true;
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      // Move to next word
      wordIndex = (wordIndex + 1) % words.length;
      typeSpeed = 400;
    }
    
    setTimeout(type, typeSpeed);
  }

  // Start typewriter after page load
  window.addEventListener('DOMContentLoaded', () => {
    setTimeout(type, 1000);
  });
</script>
